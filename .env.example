# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/taiwan_bingo
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:5432/taiwan_bingo

# Application
APP_NAME=Taiwan Bingo Predictor
